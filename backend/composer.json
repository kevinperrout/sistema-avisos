{
  "name": "p1/quiz",
  "description": "Sistema de avisos - Avaliação Final",
  "type": "project",
  "require": {
    "slim/slim": "^4.13",
    "slim/psr7": "^1.6",
    "php-di/php-di": "^7.0",
    "vlucas/phpdotenv": "^5.6",
    "psr/http-message": "^2.0"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "pestphp/pest": "^2.36"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "process-timeout": 0,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "scripts": {
    "start": "php -S localhost:8080 -t public public/router.php",
    "migrate": "php db\\Migrations\\migrate.php",
    "seed": "php db\\Seed\\seed.php",
    "test": "php vendor\\bin\\pest",
    "analyse": "phpstan analyse src --autoload-file=phpstan-bootstrap.php"
  }
}
